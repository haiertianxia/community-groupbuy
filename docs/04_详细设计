### 3.2 成团检测任务逻辑
```go
func CheckActivityEnd() {
    // 1. 查询所有"进行中"且"已到结束时间"的活动
    activities := activityRepo.FindExpiredRunning()
    for _, act := range activities {
        if act.CurrentPeople >= act.MinPeople {
            // 成团成功
            act.Status = StatusGroupSuccess
            // 更新所有参与用户订单状态
            // 发送成团通知
        } else {
            // 成团失败
            act.Status = StatusGroupFailed
            // 触发退款流程
            // 发送失败通知
        }
        activityRepo.Save(act)
    }
}
```

