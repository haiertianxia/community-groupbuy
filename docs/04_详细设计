### 2.2 限流中间件
```go
// 基于Redis + 令牌桶
func RateLimitMiddleware(rate int, burst int) gin.HandlerFunc {
    return func(c *gin.Context) {
        key := "ratelimit:" + c.ClientIP()
        count, _ := redis.Incr(key)
        if count == 1 {
            redis.Expire(key, time.Minute)
        }
        if count > int64(rate) {
            c.JSON(429, Resp{Code: 1001, Message: "请求过于频繁"})
            c.Abort()
            return
        }
        c.Next()
    }
}
```

