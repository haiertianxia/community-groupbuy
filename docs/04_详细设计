## 四、缓存设计

### 4.1 缓存Key规范
```
product:{id}                    # 商品详情, TTL=10min
products:list:{hash}            # 商品列表(带筛选条件), TTL=5min
activity:{id}                   # 活动详情, TTL=5min
leader:{id}                    # 团长信息, TTL=30min
user:session:{user_id}          # Session, TTL=14天
sms:code:{phone}               # 验证码, TTL=5min
lock:stock:{sku_hash}           # 库存分布式锁, TTL=30s
lock:order:{order_id}           # 订单操作锁, TTL=10s
rate:{ip}                       # 限流计数, TTL=1min
```

### 4.2 库存扣减（Redis + MySQL）
```go
func DecrStock(skuHash string, quantity int) error {
    // 1. Redis原子扣减
    newStock := redis.DecrBy("stock:"+skuHash, quantity)
    if newStock < 0 {
        redis.IncrBy("stock:"+skuHash, quantity) // 回滚
        return ErrStockNotEnough
    }
    // 2. MySQL乐观锁更新
    affected := db.Model(&SKU{}).Where("sku_hash = ? AND stock >= ?", skuHash, quantity).
        Update("stock", gorm.Expr("stock - ?", quantity))
    if affected.RowsAffected == 0 {
        redis.IncrBy("stock:"+skuHash, quantity) // 回滚Redis
        return ErrStockNotEnough
    }
    return nil
}
```

